{
  "manifest_version": 3,
  "name": "AWA Megumin's Alien Center",
  "version": "1.1.1",
  "description": "A tool to handle infos on AWA.",
  "icons": {
    "16":  "icons/16.png",
    "32":  "icons/32.png",
    "48":  "icons/48.png",
    "128": "icons/128.png"
  },
  "host_permissions": [
    "*://*.alienwarearena.com/*",
    "https://raw.githubusercontent.com/MeguminShiro/awa-megumin-alien-center/main/event.json"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.alienwarearena.com/*"],
      "js": ["lang.js", "center.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["var.js","eqart.js"],
      "matches": ["*://*.alienwarearena.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "awa@meguminshiro.bakuretsu"
    }
  }
}
